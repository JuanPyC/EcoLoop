# Example environment variables for EcoLoop backend
# Copy to .env and edit for your environment

PORT=3001
NODE_ENV=development

# Postgres DATABASE_URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://ecoloop_user:ecoloop_pass@localhost:5432/ecoloop

# JWT secret used to sign tokens (change in production)
JWT_SECRET=please_change_this_secret
JWT_EXPIRES_IN=7d

# Bcrypt salt rounds
BCRYPT_SALT_ROUNDS=10

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000